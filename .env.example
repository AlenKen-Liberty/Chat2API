# Chat2API configuration (example)
# Copy this file to .env if you want env overrides on top of config.yaml.

# Optional custom config path
# CHAT2API_CONFIG=/absolute/path/to/config.yaml

# Optional server overrides
CHAT2API_HOST=127.0.0.1
CHAT2API_PORT=8000

# Gemini OAuth Config (used for refreshing tokens)
# Set these to your Google OAuth client ID and secret
# GEMINI_CLIENT_ID="your_google_oauth_client_id"
# GEMINI_CLIENT_SECRET="your_google_oauth_client_secret"
